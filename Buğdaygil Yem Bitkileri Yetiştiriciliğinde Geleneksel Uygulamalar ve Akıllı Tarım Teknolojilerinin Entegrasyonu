    ax2.set_title('Özellik Önem Dereceleri')    
    plt.tight_layout()
    plt.show()    
    new_data = pd.DataFrame({
        'Temperature': [22, 35],
        'Rainfall': [550, 400],
        'Nitrogen': [12, 8],
        'Species': [0, 1]
    })
    pred_yield = model.predict(new_data)
    print("Yapay Zekâ Tahmini:")
