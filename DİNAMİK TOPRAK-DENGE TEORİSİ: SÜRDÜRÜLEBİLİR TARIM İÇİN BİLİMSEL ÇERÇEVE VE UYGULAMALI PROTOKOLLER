8.1 Python Yazılımı Üzerinde Simülasyon
Teorinin doğruluğunu ve tahmin gücünü test etmek için, dinamik bir simülasyon programı geliştirilmiştir:
python
import random
class Tarla:
    """
    Dinamik Toprak-Denge Teorisi Simülasyon Modeli
    Brady & Weil (2016) ve Lal (2004) temelleri üzerine kurulmuştur.
    Gerçekçi toprak dinamiklerini ve tarımsal müdahaleleri simüle eder.
    """
    def __init__(self, mikrobiyal, nitrojen, fosfor, organik_madde, yapisizlik, stres):
        """
        Args:
            mikrobiyal: 0-1 arası (FDA Activity Index)
            nitrojen: kg/ha (Kjeldahl Method)
            fosfor: kg/ha (Olsen Method)
            organik_madde: % (Walkley-Black Method)
            yapisizlik: 1-10 (Penetrometer Index, düşük = iyi)
            stres: 1-10 (Composite Stress Index, düşük = iyi)
        """
        self.M = mikrobiyal
        self.N = nitrojen
        self.P = fosfor
        self.B = organik_madde
        self.S = yapisizlik
        self.L = stres
        self.tarih = []          # TDK geçmişi
        self.bitki_dongusu = 0
    def _hesapla_TDK(self, kaydet=True):
        """
        TDK (Toprak Denge Katsayısı) hesaplar.
        Formül: ((M + N/100 + P/100) * B) / (S * L)
        """
        pay = (self.M + self.N/100 + self.P/100) * self.B
        payda = self.S * self.L
        if payda == 0:
            tdk = 0.0
        else:
            tdk = pay / payda
        if kaydet:
            self.tarih.append(tdk)
        return round(tdk, 3)
    def hesapla_TDK(self):
        """Dışarıdan çağrıldığında hesaplar ve geçmişe kaydeder."""
        return self._hesapla_TDK(kaydet=True)
    def uretim_onerisi(self, tdk=None):
        """
        TDK'ye göre üretime uygunluk değerlendirmesi.
        Eğer tdk verilmezse mevcut duruma göre hesaplar (geçmişe kaydeder).
        """
        if tdk is None:
            tdk = self._hesapla_TDK(kaydet=True)
        if tdk >= 1.5:
            return f"✅ TDK = {tdk}: Altın Seviye - Optimal üretim, premium pazar uygun"
        elif tdk >= 1.2:
            return f"✅ TDK = {tdk}: Gümüş Seviye - İyi üretim ve pazarlama olanağı"
        elif tdk >= 1.0:
            return f"🟡 TDK = {tdk}: Yeşil Seviye - Üretime hazır, rutin bakım gerekli"
        elif tdk >= 0.8:
            return f"⚠️ TDK = {tdk}: Sarı Seviye - Sınır durumda, iyileştirme tavsiye edilir"
        elif tdk >= 0.5:
            return f"🔴 TDK = {tdk}: Kırmızı Seviye - Rehabilitasyon protokolü uygulanmalı"
        else:
            return f"🛑 TDK = {tdk}: Kritik - Tarım dışı kalması gerekli veya büyük restorasyon"
    def sezonsal_guncelle(self, bitki_tipi="ortalama", mudahale="none"):
        """
        Sezonluk değişim simülasyonu.
        Bitki tipine ve yapılan müdahaleye göre toprak parametrelerini günceller.
        Kaynaklar: Brady & Weil (2016), Bloem et al. (1995), Kallenbach et al. (2016), FAO (2017)
        """
        # ===== 1. BİTKİ ETKİSİ (hasat, kök aktivitesi, ölü örtü) =====
        # Bitki tipine göre besin alımı farklılaşır
        if bitki_tipi == "bugday":
            n_kayip = random.uniform(18, 28)
            p_kayip = random.uniform(8, 14)
            m_kayip = random.uniform(0.06, 0.12)
            b_kayip = random.uniform(0.08, 0.14)
        elif bitki_tipi == "misir":
            n_kayip = random.uniform(22, 32)
            p_kayip = random.uniform(10, 16)
            m_kayip = random.uniform(0.07, 0.14)
            b_kayip = random.uniform(0.10, 0.18)
        elif bitki_tipi == "yonca" or bitki_tipi == "baklagil":
            # Baklagiller N sabitler, bu nedenle N kaybı olmaz, hatta artabilir
            n_kayip = -random.uniform(15, 30)   # negatif kayıp = kazanç
            p_kayip = random.uniform(5, 10)
            m_kayip = random.uniform(0.03, 0.06)  # daha az mikrobiyal stres
            b_kayip = random.uniform(0.04, 0.08)
        else:  # ortalama bitki
            n_kayip = random.uniform(15, 25)
            p_kayip = random.uniform(5, 12)
            m_kayip = random.uniform(0.05, 0.12)
            b_kayip = random.uniform(0.05, 0.15)
        self.N = max(self.N - n_kayip, 5)   # kg/ha alt sınır
        self.P = max(self.P - p_kayip, 3)
        self.M = max(self.M - m_kayip, 0.05)
        self.B = max(self.B - b_kayip, 0.3)
        # ===== 2. MÜDAHALELERİN ETKİSİ =====
        # Her müdahale toprağı iyileştirir veya bozar
        if mudahale == "yesil_gubre":
            # FAO (2017): Baklagil-çim karması ekim
            self.N += random.uniform(40, 60)
            self.M = min(self.M + random.uniform(0.12, 0.18), 1.0)
            self.B = min(self.B + random.uniform(0.3, 0.5), 5.0)
            self.S = max(self.S - random.uniform(0.3, 0.6), 1)

        elif mudahale == "kompost":
            # Kallenbach et al. (2016): Organik madde artışı
            self.M = min(self.M + random.uniform(0.15, 0.25), 1.0)
            self.B = min(self.B + random.uniform(0.5, 1.0), 5.0)
            self.N += random.uniform(20, 35)
            self.P += random.uniform(8, 15)
        elif mudahale == "minimal_isleme":
            # FAO (2017): Koruyucu tarım
            self.S = max(self.S - random.uniform(0.5, 1.0), 1)
            self.M = min(self.M + random.uniform(0.05, 0.08), 1.0)
            self.B = min(self.B + random.uniform(0.1, 0.2), 5.0)
        elif mudahale == "kimyasal_gubre":
            # Geleneksel uygulama: kısa vadeli besin artışı, mikrobiyal baskılama
            self.N += random.uniform(50, 80)
            self.P += random.uniform(15, 25)
            self.M = max(self.M - random.uniform(0.08, 0.15), 0.05)
        elif mudahale == "pestisit":
            # Bloem et al. (1995): Mikrobiyal çeşitlilik kaybı
            self.M = max(self.M - random.uniform(0.2, 0.35), 0.05)
        elif mudahale == "yonca":
            # Brady & Weil (2016): Azot sabitleme
            self.N = min(self.N + random.uniform(80, 120), 300)
            self.M = min(self.M + random.uniform(0.08, 0.15), 1.0)
            self.B = min(self.B + random.uniform(0.2, 0.35), 5.0)
        elif mudahale == "malc":
            # Malç uygulaması: organik madde koruma, su tutma
            self.B = min(self.B + random.uniform(0.2, 0.4), 5.0)
            self.M = min(self.M + random.uniform(0.05, 0.10), 1.0)
            self.S = max(self.S - random.uniform(0.1, 0.3), 1)
        # ===== 3. ÇEVRESEL STRES FAKTÖRÜ (iklim, kuraklık, sel, vs.) =====
        # Stres indeksi zamanla değişir
        self.L += random.uniform(-1.0, 1.0)
        self.L = max(1, min(10, self.L))   # 1-10 arasında tut
        # ===== 4. DOĞAL KAYIPLAR (erozyon, ayrışma, yıkanma) =====
        # Lal (2004) - organik madde kaybı
        self.B = max(self.B - random.uniform(0.03, 0.10), 0.3)
        # Besin yıkanması (özellikle N)
        self.N = max(self.N - random.uniform(2, 8), 5)
        # Döngü sayacı
        self.bitki_dongusu += 1
        # Yeni TDK'yı hesapla ve döndür (geçmişe kaydet)
        return self._hesapla_TDK(kaydet=True)
    def akilli_bildirim(self):
        """AI-Destekli Tavsiye Sistemi - mevcut duruma göre öneriler üretir."""
        tdk = self._hesapla_TDK(kaydet=False)  # geçmişe kaydetmeden hesapla
        mesajlar = []
        if self.M < 0.4:
            mesajlar.append("🔴 ACİL: Mikrobiyal Çeşitlilik Çok Düşük (M={:.2f})".format(self.M))
            mesajlar.append("   → Yeşil gübre ekimi zorunlu (FDA aktivitesi ↑)")
            mesajlar.append("   → Kompost çayı uygulaması (2 hafta aralığı)")
            mesajlar.append("   → Pestisit yasağı (6 ay)")
        if self.B < 1.5:
            mesajlar.append("🟠 Organik Madde Düşük (B={:.1f}%)".format(self.B))
            mesajlar.append("   → Malç uygulaması (20-30 ton/ha kompost)")
            mesajlar.append("   → Hasat kalıntısını tarlada bırak")
        if self.S > 5:
            mesajlar.append("🟠 Toprak Sıkışıklığı Yüksek (S={:.1f})".format(self.S))
            mesajlar.append("   → Minimal toprak işleme veya doğrudan ekim")
            mesajlar.append("   → Derin sürüm (40 cm) - sadece ilk sezon")
        if self.N < 50:
            mesajlar.append("🟡 Nitrojen Kısıtlı (N={:.0f} kg/ha)".format(self.N))
            if self.M > 0.6:
                mesajlar.append("   → Yeşil gübre (M yüksek, toprak N sağlayabilir)")
            else:
                mesajlar.append("   → Yonca ekimi tavsiye edilir")
        elif self.N < 80:
            mesajlar.append("🟢 Nitrojen Yeterli (N={:.0f} kg/ha) - dengede".format(self.N))
        if self.L > 6:
            mesajlar.append("🟡 Çevresel Stres Yüksek (L={:.1f})".format(self.L))
            mesajlar.append("   → Malç uygulaması (su tutma kapasitesi ↑)")
            mesajlar.append("   → Sulama sistemi kurmayı düşün")
        if tdk < 0.5:
            mesajlar.append("🛑 TDK Kritik Seviyede: Rehabilitasyon protokolü ZORUNLU")
            mesajlar.append("   → 36 aylık Program: Fiziksel → Mikrobiyolojik → Tarım Dönüşü")
        if not mesajlar:
            mesajlar.append(f"✅ Mevcut TDK: {tdk:.2f} - Her şey kontrol altında")
        return mesajlar
