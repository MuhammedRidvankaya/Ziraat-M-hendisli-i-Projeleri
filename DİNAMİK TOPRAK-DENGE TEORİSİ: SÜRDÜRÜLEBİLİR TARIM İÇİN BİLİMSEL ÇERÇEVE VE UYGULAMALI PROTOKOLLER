import logging
from typing import List, Dict, Optional
from datetime import datetime, timedelta
# ================== Loglama Ayarları ==================
logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')
# ================== Basit Veri Saklama (Simülasyon) ==================
tdk_history = []  # (timestamp, TDK)
# ================== Yardımcı Fonksiyonlar ==================
def fetch_from_sensors() -> List[Dict]:
    """Sensör verilerini simüle eder."""
    return [
        {'microbe_activity': 0.6, 'nitrogen': 85.0, 'phosphorus': 12.0,
         'penetration_resistance': 3.2},
        {'microbe_activity': 0.7, 'nitrogen': 90.0, 'phosphorus': 11.5,
         'penetration_resistance': 3.0},
    ]
def average(values: List[float]) -> Optional[float]:
    if not values:
        return None
    return sum(values) / len(values)
def estimate_organic_matter(N_avg: float, microbial_activity_avg: float) -> float:
    return (microbial_activity_avg * 2.5) + (N_avg / 200.0)
def estimate_compaction(penetration_avg: float) -> float:
    return penetration_avg
def estimate_stress(temp_data: List[float], rainfall_data: List[float],
                    contamination_data: List[float]) -> float:
    if not contamination_data:
        return 1.0
    avg_cont = sum(contamination_data) / len(contamination_data)
    return min(10.0, avg_cont * 2.0)
def get_historical_TDK(days_ago: int = 7) -> Optional[float]:
    """
    Geçmişteki TDK değerini döndürür (en yakın kayıt).
    - days_ago: Kaç gün önceki değer isteniyor (varsayılan 7).
    """
    target_time = datetime.now() - timedelta(days=days_ago)
    if not tdk_history:
        return None
    # Zaman farkı en küçük olan kaydı bul
    closest = min(tdk_history, key=lambda x: abs((x[0] - target_time).total_seconds()))
    return closest[1]
def trigger_alert(reason: str, severity: str = "WARNING"):
    logging.warning(f"ALERT ({severity}): {reason}")
def identify_problem(M_avg: float, N_avg: float, B_avg: float,
                     S_avg: float, L_avg: float) -> str:
    if M_avg < 0.5:
        return "Düşük mikrobiyal aktivite"
    if B_avg < 1.5:
        return "Düşük organik madde"
    if S_avg > 5.0:
        return "Yüksek toprak sıkışması"
    if L_avg > 6.0:
        return "Yüksek çevresel stres"
    if N_avg < 80:
        return "Azot eksikliği"
    return "Belirsiz neden"
def save_to_database(TDK: float, timestamp: datetime, sensor_data: List[Dict]):
    """TDK ve sensör verilerini kaydeder."""
    global tdk_history
    tdk_history.append((timestamp, TDK))
    # NOT: Eski kayıtları silme işlemi kaldırıldı; istenirse ayrı bir fonksiyonla yapılabilir.
    logging.info(f"TDK kaydedildi: {TDK:.4f} @ {timestamp}")
def recommend(action: str, priority: str, details: str = ""):
    logging.info(f"TAVSİYE [{priority}]: {action} - {details}")
def generate_recommendations(M: float, N: float, B: float, S: float, L: float):
    if M < 0.5:
        recommend("Mikrobiyal aktiviteyi artırın", "YÜKSEK",
                  "Kompost veya organik gübre uygulayın, toprak işlemeyi azaltın.")
    if B < 1.5:
        recommend("Organik madde miktarını artırın", "YÜKSEK",
                  "Yeşil gübre, kompost veya organik malç ekleyin.")
    if S > 5.0:
        recommend("Toprak sıkışmasını azaltın", "YÜKSEK",
   "Derin köklü bitkiler ekin, mekanik gevşetme yapın.")
    if L > 6.0:
        recommend("Çevresel stresi azaltın", "ORTA",
                  "Sulama düzenini gözden geçirin, gölgelik veya rüzgar kıran kullanın.")
    if N < 80:
        recommend("Azot takviyesi yapın", "ORTA",
                  "Azotlu gübre uygulayın.")
    # Her şey iyiyse
    if M >= 0.5 and B >= 1.5 and S <= 5.0 and L <= 6.0 and N >= 80:
        recommend("Mevcut uygulamaları sürdürün", "DÜŞÜK",
                  "Toprak kalitesi iyi durumda, düzenli izlemeye devam edin.")
# ================== ANA FONKSİYON ==================
def calculate_realtime_TDK():
    global tdk_history
    sensor_data = fetch_from_sensors()
    if not sensor_data:
        logging.error("Sensör verisi alınamadı.")
        return None
    microbe_values = [s.get('microbe_activity') for s in sensor_data if s.get('microbe_activity') is not None]
    nitrogen_values = [s.get('nitrogen') for s in sensor_data if s.get('nitrogen') is not None]
    phosphorus_values = [s.get('phosphorus') for s in sensor_data if s.get('phosphorus') is not None]
    penetration_values = [s.get('penetration_resistance') for s in sensor_data if s.get('penetration_resistance') is not None]
    M_avg = average(microbe_values)
    N_avg = average(nitrogen_values)
    P_avg = average(phosphorus_values)
    S_avg_raw = average(penetration_values)
    if None in (M_avg, N_avg, P_avg, S_avg_raw):
        logging.error("Kritik sensör verileri eksik.")
        return None
    B_avg = estimate_organic_matter(N_avg, M_avg)
    S_avg = estimate_compaction(S_avg_raw)
    temperature_data = [25.0, 26.0]
    rainfall_data = [0.0, 2.5]
    contamination_data = [0.1, 0.2]
    L_avg = estimate_stress(temperature_data, rainfall_data, contamination_data)
    if S_avg == 0 or L_avg == 0:
        logging.error("Sıkışma veya stres sıfır, hesaplama iptal.")
        return None
    TDK = ((M_avg + N_avg/100 + P_avg/100) * B_avg) / (S_avg * L_avg)
    prev_TDK = get_historical_TDK(days_ago=7)
    if prev_TDK is not None:
        TDK_change = TDK - prev_TDK
        if TDK_change < -0.1:
            problem = identify_problem(M_avg, N_avg, B_avg, S_avg, L_avg)
            trigger_alert(f"TDK 0.1'den fazla düştü. Olası neden: {problem}", severity="HIGH")
    else:
        logging.info("7 gün önceki TDK verisi yok, karşılaştırma atlandı.")
    generate_recommendations(M_avg, N_avg, B_avg, S_avg, L_avg)
    save_to_database(TDK, datetime.now(), sensor_data)
    logging.info(f"Hesaplanan TDK: {TDK:.4f}")
    return TDK
# ================== ÖRNEK ÇALIŞTIRMA ==================
if __name__ == "__main__":
    # Geçmiş kayıtlar (simülasyon)
    now = datetime.now()
    for i in range(10, 0, -1):
        t = now - timedelta(days=i, hours=5)  # saat farkı olsun
        fake_tdk = 1.0 + (i * 0.05)
        tdk_history.append((t, fake_tdk))
    tdk = calculate_realtime_TDK()
    print(f"Son TDK: {tdk}")
