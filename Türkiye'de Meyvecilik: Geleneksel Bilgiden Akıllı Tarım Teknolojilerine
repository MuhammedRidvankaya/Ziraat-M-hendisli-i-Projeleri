@dataclass
class ToprakAnalizi:
    pH: float
    tuzluluk_dS_m: float
    organik_madde_yuzde: float
    kum_yuzde: float
    kil_yuzde: float
    silt_yuzde: float
    azot_ppm: float
    fosfor_ppm: float
    potasyum_ppm: float
    kalsiyum_ppm: float
    magnezyum_ppm: float
    su_tutma_kapasitesi_mm_m: float  # mm su / m toprak
    derinlik_cm: int    
    @property
    def toprak_tipi(self) -> ToprakTipi:
        if self.kum_yuzde > 70:
            return ToprakTipi.KUM
        elif self.kil_yuzde > 40:
            return ToprakTipi.KIL
        elif self.kum_yuzde > 50 and self.silt_yuzde < 30:
            return ToprakTipi.TINLI_KUM
        elif self.kil_yuzde > 30 and self.silt_yuzde > 30:
            return ToprakTipi.TINLI_KIL
        else:
            return ToprakTipi.TIN    
    def uygun_mu(self, meyve: Meyve) -> Tuple[bool, List[str]]:
        uygun = True
        sebepler = []
        if not (meyve.pH_araligi[0] <= self.pH <= meyve.pH_araligi[1]):
            uygun = False
            sebepler.append(f"pH ({self.pH}) meyve için uygun değil ({meyve.pH_araligi})")
        if self.tuzluluk_dS_m > meyve.tuzluluk_toleransi:
            uygun = False
            sebepler.append(f"Tuzluluk ({self.tuzluluk_dS_m} dS/m) toleransı aşıyor ({meyve.tuzluluk_toleransi})")
        if self.toprak_tipi != meyve.toprak_istegi and meyve.toprak_istegi != ToprakTipi.TIN:
            if self.toprak_tipi == ToprakTipi.KUM and meyve.su_ihtiyaci == "Yüksek":
                uygun = False
                sebepler.append(f"Kumlu toprak yüksek su ihtiyacı olan meyve için uygun değil")
        return uygun, sebepler
@dataclass
class IklimVerileri:
    yillik_ortalama_sicaklik: float
    en_dusuk_sicaklik: float
    en_yuksek_sicaklik: float
    yillik_yagis_mm: float
    don_riski_gun_sayisi: int
    hakim_ruzgar_yonu: str
    nem_ortalamasi: float
    guneslenme_suresi_saat: float
    ciceklenme_donemi_don_riski: bool = False
    def uygun_mu(self, meyve: Meyve) -> Tuple[bool, List[str]]:
        uygun = True
        sebepler = []
        if self.en_dusuk_sicaklik < meyve.sicaklik_istegi[0]:
            uygun = False
            sebepler.append(f"En düşük sıcaklık ({self.en_dusuk_sicaklik}) meyvenin toleransının altında ({meyve.sicaklik_istegi[0]})")
        if self.en_yuksek_sicaklik > meyve.sicaklik_istegi[1]:
            uygun = False
            sebepler.append(f"En yüksek sıcaklık ({self.en_yuksek_sicaklik}) meyvenin toleransının üstünde ({meyve.sicaklik_istegi[1]})")
        if meyve.su_ihtiyaci == "Yüksek" and self.yillik_yagis_mm < 600:
            uygun = False
            sebepler.append(f"Meyve yüksek su ihtiyacı var, yıllık yağış ({self.yillik_yagis_mm}) yetersiz")
        return uygun, sebepler
@dataclass
class Arazi:
    enlem: float
    boylam: float
    yukseklik_m: int
    egim_derece: float
    yoney: str  # Kuzey, Güney, Doğu, Batı
    alan_m2: float
    toprak: ToprakAnalizi
    iklim: IklimVerileri
    mevcut_bitki_ortusu: str = ""
    onceki_kullanim: str = ""    
    def dikim_uygunlugu(self, meyve: Meyve) -> Dict:
        toprak_uygun, toprak_neden = self.toprak.uygun_mu(meyve)
        iklim_uygun, iklim_neden = self.iklim.uygun_mu(meyve)        
        uygunluk_puani = 0
        if toprak_uygun:
            uygunluk_puani += 50
        else:
            uygunluk_puani += len(toprak_neden) * -5            
        if iklim_uygun:
            uygunluk_puani += 50
        else:
            uygunluk_puani += len(iklim_neden) * -5         
        # Yöney ve eğim etkisi
        if self.yoney.lower() == "güney":
            uygunluk_puani += 10
        elif self.yoney.lower() == "kuzey" and meyve.sicaklik_istegi[0] < -5:
            uygunluk_puani += 5
        else:
            uygunluk_puani -= 5            
        if self.egim_derece < 10:
            uygunluk_puani += 5
        elif self.egim_derece > 30:
            uygunluk_puani -= 10            
        return {
            "meyve": meyve.ad,
            "toprak_uygun": toprak_uygun,
            "iklim_uygun": iklim_uygun,
            "uygunluk_puani": max(0, min(100, uygunluk_puani)),
            "riskler": toprak_neden + iklim_neden,
            "oneriler": self._get_oneriler(meyve)
        }    
    def _get_oneriler(self, meyve: Meyve) -> List[str]:
        oneriler = []
        if not self.toprak.uygun_mu(meyve)[0]:
            if self.toprak.pH < meyve.pH_araligi[0]:
                oneriler.append("Kireçleme yaparak pH'ı yükseltin.")
            elif self.toprak.pH > meyve.pH_araligi[1]:
                oneriler.append("Asit karakterli gübrelerle pH'ı düşürün.")
            if self.toprak.tuzluluk_dS_m > meyve.tuzluluk_toleransi:
                oneriler.append("Yıkama suyu ile tuzluluğu azaltın.")
        if self.egim_derece > 15:
            oneriler.append("Teraslama yaparak erozyonu önleyin.")
        if self.iklim.don_riski_gun_sayisi > 30 and meyve.botanik.ciceklenme_zamani == "İlkbahar":
            oneriler.append("Geç don riskine karşı sisleme veya rüzgar makinesi kullanın.")
        return oneriler
