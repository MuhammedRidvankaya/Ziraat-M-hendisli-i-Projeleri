class Fidan:
    def __init__(self, meyve: Meyve, toprak: ToprakAnalizi, iklim: IklimVerileri):
        self.meyve = meyve
        self.yas = 0
        self.boy_cm = 50
        self.tac_cap_m = 0.5
        self.saglik_durumu = 1.0
        self.toprak = toprak
        self.iklim = iklim
        self.verim_gecmisi = []        
    def yil_gec(self, bakim_kalitesi: float = 0.8):
        self.yas += 1
        if self.yas <= 5:
            self.boy_cm += 30 * bakim_kalitesi
            self.tac_cap_m += 0.2 * bakim_kalitesi
        elif self.yas <= 10:
            self.boy_cm += 15 * bakim_kalitesi
            self.tac_cap_m += 0.1 * bakim_kalitesi
        else:
            self.boy_cm += 5 * bakim_kalitesi
            self.tac_cap_m += 0.05 * bakim_kalitesi
        self.saglik_durumu *= (0.95 + 0.05 * bakim_kalitesi)
        if self.iklim.don_riski_gun_sayisi > 20:
            self.saglik_durumu *= 0.98
        if self.toprak.tuzluluk_dS_m > self.meyve.tuzluluk_toleransi:
            self.saglik_durumu *= 0.97        
    def tahmini_verim(self, yil_no: int) -> float:
        if yil_no < self.meyve.verim_baslangic_yil:
            return 0.0
        yas_etkisi = min(1.0, (yil_no - self.meyve.verim_baslangic_yil) / (self.meyve.tam_verim_yil - self.meyve.verim_baslangic_yil))
        verim_katsayisi = 0.5 + 0.5 * yas_etkisi
        tac_hacmi = (4/3) * math.pi * (self.tac_cap_m/2)**3
        max_verim = tac_hacmi * 10
        verim = max_verim * verim_katsayisi * self.saglik_durumu
        return max(0, verim)    
    def durum_raporu(self) -> Dict:
        return {
            "meyve_turu": self.meyve.ad,
            "yas": self.yas,
            "boy_cm": self.boy_cm,
            "tac_cap_m": self.tac_cap_m,
            "saglik_durumu": f"{self.saglik_durumu:.2f}",
            "tahmini_verim_kg": self.tahmini_verim(self.yas + 1)
        }
