        self.id = sensor_id
        self.tip = tip
        self.konum = konum
        self.degerler = []        
    def olcum_yap(self) -> float:
        if self.tip == "toprak_nem":
            gercek = random.uniform(20, 80)
        elif self.tip == "sicaklik":
            gercek = random.uniform(-5, 40)
        elif self.tip == "pH":
            gercek = random.uniform(5.5, 8.5)
        elif self.tip == "tuzluluk":
            gercek = random.uniform(0.5, 4.0)
        else:
            gercek = 0
        olcum = gercek + random.gauss(0, 0.5)
        self.degerler.append((datetime.now(), olcum))
        return olcum    
    def son_veri(self) -> Tuple[datetime, float]:
        if self.degerler:
            return self.degerler[-1]
        return (None, None)
class YapayZekaModeli:
