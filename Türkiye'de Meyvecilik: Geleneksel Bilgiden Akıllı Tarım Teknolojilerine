        self.model_agirliklari = {"accuracy": random.uniform(0.85, 0.95)}        
    def hastalik_tanima(self, yaprak_gorseli: Any) -> Dict:
        hastaliklar = ["Elma Kara Leke", "Külleme", "Bakteriyel Yanıklık", "Sağlıklı"]
        tahmin = random.choice(hastaliklar)
        guven = random.uniform(0.6, 0.99)
        return {
            "hastalik": tahmin,
