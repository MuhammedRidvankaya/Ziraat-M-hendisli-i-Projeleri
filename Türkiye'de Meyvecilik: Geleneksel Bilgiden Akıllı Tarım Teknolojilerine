@dataclass
class DikimPlani:
    meyve_turu: str
    fidan_sayisi: int
    sira_arasi_m: float
    fidan_arasi_m: float
    dikim_sistemi: DikimSistemi
    tozlayici_orani: float = 0.0
    tozlayici_tur: Optional[str] = None    
    def fidan_basina_alan(self) -> float:
        if self.dikim_sistemi == DikimSistemi.KARE:
            return self.sira_arasi_m * self.fidan_arasi_m
        elif self.dikim_sistemi == DikimSistemi.DIKDORTGEN:
            return self.sira_arasi_m * self.fidan_arasi_m
        elif self.dikim_sistemi == DikimSistemi.SATRANC:
            return (self.sira_arasi_m * self.fidan_arasi_m) * 0.85
        else:
            return self.sira_arasi_m * self.fidan_arasi_m * 0.866    
    def toplam_alan(self) -> float:
        return self.fidan_sayisi * self.fidan_basina_alan()
class Bahce:
    def __init__(self, ad: str, arazi: Arazi):
        self.ad = ad
        self.arazi = arazi
        self.dikim_planlari: List[DikimPlani] = []
        self.fidanlar: List['Fidan'] = []
        self.yil = 0
        self.uretim_kayitlari: List[Dict] = []        
    def dikim_plani_ekle(self, plan: DikimPlani):
        # Toplam alan kontrolü: mevcut planların alanı + yeni planın alanı
        kullanilan_alan = sum(p.toplam_alan() for p in self.dikim_planlari)
        yeni_toplam_alan = kullanilan_alan + plan.toplam_alan()
        if yeni_toplam_alan > self.arazi.alan_m2:
            raise ValueError(f"Alan yetersiz. Mevcut alan kullanımı: {kullanilan_alan:.1f} m², "
                             f"yeni plan {plan.toplam_alan():.1f} m² gerektiriyor, toplam alan {self.arazi.alan_m2} m².")
        self.dikim_planlari.append(plan)
        # Fidanları oluştur
        meyve = Meyveler.get(plan.meyve_turu)
        if not meyve:
            raise ValueError(f"Meyve türü {plan.meyve_turu} tanımlı değil.")
        for i in range(plan.fidan_sayisi):
            self.fidanlar.append(Fidan(meyve, self.arazi.toprak, self.arazi.iklim))            
    def bahceyi_kur(self, dikim_tarihi: datetime):
        print(f"\n=== {self.ad} Bahçesi Kuruluyor ===")
        print(f"Arazi: {self.arazi.alan_m2} m², Eğim: {self.arazi.egim_derece}°, Yöney: {self.arazi.yoney}")
        print(f"Toprak: pH={self.arazi.toprak.pH}, Tuzluluk={self.arazi.toprak.tuzluluk_dS_m} dS/m")
        print(f"İklim: Yıllık Yağış={self.arazi.iklim.yillik_yagis_mm} mm, Don Riski Gün={self.arazi.iklim.don_riski_gun_sayisi}")
        print("\nDikim Planları:")
        for plan in self.dikim_planlari:
            print(f" - {plan.meyve_turu}: {plan.fidan_sayisi} fidan, "
                  f"Sıra arası {plan.sira_arasi_m} m, Fidan arası {plan.fidan_arasi_m} m, "
                  f"Sistem: {plan.dikim_sistemi.value}")
        print(f"\nToplam {len(self.fidanlar)} fidan dikildi.")
   self.yil = 0
        self.uretim_kayitlari.append({
            "yil": 0,
            "tarih": dikim_tarihi,
            "islem": "Bahçe Kurulumu",
            "detay": f"{len(self.fidanlar)} fidan dikildi"
        })        
    def yillik_bakim(self, yil_no: int, bakim_raporu: Dict):
        print(f"\n--- {yil_no}. Yıl Bakım İşlemleri ---")
        if yil_no >= 1:
            print("Toprak işleme yapıldı (pulluk, kültivatör).")
        if yil_no >= 2:
            print("Kış budaması yapıldı.")
        if yil_no >= 3 and yil_no % 2 == 0:
            print("Yaz budaması (yeşil budama) yapıldı.")
        if self.arazi.iklim.yillik_yagis_mm < 500:
            print("Damla sulama sistemi ile sulama yapıldı.")
        if self.arazi.toprak.azot_ppm < 50:
            print("Azotlu gübre uygulandı.")
        if self.arazi.toprak.fosfor_ppm < 20:
            print("Fosforlu gübre uygulandı.")
        if yil_no % 2 == 0:
            print("Kış ilaçlaması (bordo bulamacı) yapıldı.")
        if yil_no >= 3:
            print("Entegre mücadele kapsamında biyolojik ilaçlama yapıldı.")            
        verim = 0
        if yil_no >= 3:
            verim = self._verim_hesapla(yil_no)
            print(f"Hasat yapıldı. Toplam verim: {verim:.2f} kg")
            self.uretim_kayitlari.append({
                "yil": yil_no,
                "verim_kg": verim,
                "islem": "Hasat",
                "detay": bakim_raporu
            })
        return verim    
    def _verim_hesapla(self, yil_no: int) -> float:
        toplam_verim = 0
        for fidan in self.fidanlar:
            toplam_verim += fidan.tahmini_verim(yil_no)
        return toplam_verim    
    def rapor_al(self) -> Dict:
        toplam_verim = sum([k.get("verim_kg", 0) for k in self.uretim_kayitlari])
        return {
            "bahce_adi": self.ad,
            "kurulum_yili": self.uretim_kayitlari[0]["tarih"].year if self.uretim_kayitlari else None,
            "fidan_sayisi": len(self.fidanlar),
            "uretim_yillari": len([k for k in self.uretim_kayitlari if "verim_kg" in k]),
            "toplam_uretim_kg": toplam_verim,
            "ortalama_verim_kg_fidan": toplam_verim / len(self.fidanlar) if self.fidanlar else 0,
            "detayli_kayitlar": self.uretim_kayitlari
        }
