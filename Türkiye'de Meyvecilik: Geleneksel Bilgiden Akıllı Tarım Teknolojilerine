class HasatYoneticisi:
    @staticmethod
    def olgunluk_testi(meyve: Meyve, meyve_ornegi: Dict) -> Dict:
        sonuc = {
            "meyve_adi": meyve.ad,
            "hasat_zamani_geldi_mi": False,
            "kriterler": {}
        }
        sonuc["kriterler"]["renk"] = True
        brix_esik = 10.0 if meyve.ad == "Elma" else 12.0
        brix_uygun = meyve_ornegi["suda_cozunur_kuru_madde_brix"] >= brix_esik
        sonuc["kriterler"]["brix"] = brix_uygun        
        if meyve.grup == MeyveGrubu.YUMUSAK_CEKIRDEKLI:
            sertlik_uygun = 5.0 <= meyve_ornegi["et_sertligi_N"] <= 8.0
            sonuc["kriterler"]["et_sertligi"] = sertlik_uygun
        nisasta_uygun = meyve_ornegi["nisasta_miktari"] < 0.5
        sonuc["kriterler"]["nisasta"] = nisasta_uygun        
        gelisim_suresi_uygun = meyve_ornegi["ciceklenme_gun_sayisi"] > 90
        sonuc["kriterler"]["gelisim_suresi"] = gelisim_suresi_uygun        
        uygun_kriterler = sum([1 for v in sonuc["kriterler"].values() if v])
        toplam_kriter = len(sonuc["kriterler"])
        if uygun_kriterler / toplam_kriter >= 0.7:
            sonuc["hasat_zamani_geldi_mi"] = True
            sonuc["hasat_oneri"] = "Hemen hasat edin."
        else:
            sonuc["hasat_oneri"] = f"Henüz değil. {toplam_kriter - uygun_kriterler} kriter sağlanmamış."
        return sonuc    
    @staticmethod
    def hasat_et(meyve_turu: str, miktar_kg: float, hasat_ekipmani: str = "El ile"):
        print(f"\n=== HASAT ===")
        print(f"Meyve: {meyve_turu}, Miktar: {miktar_kg} kg, Yöntem: {hasat_ekipmani}")
        print("Meyveler dikkatlice toplandı, zedelenmemesine özen gösterildi.")
        print("Hasat sonrası soğuk zincir uygulandı.")
        return {"meyve": meyve_turu, "miktar_kg": miktar_kg, "hasat_tarihi": datetime.now()}
