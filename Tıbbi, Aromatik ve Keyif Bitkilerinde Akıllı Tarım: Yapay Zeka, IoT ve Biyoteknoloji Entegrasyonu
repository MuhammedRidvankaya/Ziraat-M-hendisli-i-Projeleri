# ------------------------ 2. IOT SENSÖR VE MİKRODENETLEYİCİ SİMÜLASYONU ------------------------
class IoTMikrodenetleyici:
    """
    Gerçek bir IoT sistemini simüle eder.
    Sensörlerden veri alır, mikrodenetleyici (Arduino/ESP32) mantığı ile karar verir.
    """
    def __init__(self, port="COM3"):
        self.port = port
        self.toprak_nem = 0
        self.sicaklik = 0
        self.nem = 0
        self.isik = 0
        self.sulama_durumu = False
        self.fan_durumu = False
        self.isitici_durumu = False
    def sensörleri_oku(self) -> Dict:
        """Simüle edilmiş sensör verileri okur"""
        self.toprak_nem = random.uniform(20, 80)  # %
        self.sicaklik = random.uniform(10, 40)    # °C
        self.nem = random.uniform(30, 90)         # %
        self.isik = random.uniform(100, 1000)     # lüx
        return {
            "toprak_nem": self.toprak_nem,
            "sicaklik": self.sicaklik,
            "nem": self.nem,
            "isik": self.isik
        }
    def mikrodenetleyici_karari(self, bitki: BitkiOzellikleri, toprak: ToprakVerisi) -> Dict:
        """
        Mikrodenetleyici, sensör verilerine ve bitki ihtiyacına göre karar verir.
        Gerçekte bu kod ESP32/Arduino'ya yüklenir.
        """
        sensör = self.sensörleri_oku()
        karar = {}
        # Sulama kararı
        if sensör["toprak_nem"] < 40:  # Örnek eşik
            karar["sulama"] = "AC"
            self.sulama_durumu = True
        else:
            karar["sulama"] = "KAPA"
            self.sulama_durumu = False
        # Isıtma/Soğutma kararı (sera için)
     if sensör["sicaklik"] < bitki.optimumSicaklikMin:
            karar["isitici"] = "AC"
            self.isitici_durumu = True
        elif sensör["sicaklik"] > bitki.optimumSicaklikMax:
            karar["fan"] = "AC"
            self.fan_durumu = True
        else:
            karar["isitici"] = "KAPA"
            karar["fan"] = "KAPA"
            self.isitici_durumu = False
            self.fan_durumu = False
        # Bildirim (IoT üzerinden kullanıcıya)
        if karar["sulama"] == "AC":
            self.bildirim_gonder("Sulama başlatıldı, toprak nemi düşük.")
        return karar
    def bildirim_gonder(self, mesaj):
        """Telefon/Web uygulamasına bildirim gönderir (simülasyon)"""
        print(f"[BİLDİRİM] {mesaj}")
# ------------------------ 3. MAKİNE ÖĞRENMESİ MODÜLÜ ------------------------
class MakineOgrenmesi:
    """
    Verim tahmini (regresyon), bitki sınıflandırma (classification) ve kalite tahmini yapar.
    """
    def __init__(self):
        self.verim_modeli = None       # RandomForestRegressor
        self.kalite_modeli = None      # RandomForestRegressor (uçucu yağ oranı)
        self.bitki_siniflandirici = None  # RandomForestClassifier
        self.scaler = StandardScaler()
    def verim_modeli_egit(self, X, y):
        """X: iklim+toprak özellikleri, y: verim (kg/da)"""
        X_scaled = self.scaler.fit_transform(X)
        self.verim_modeli = RandomForestRegressor(n_estimators=100, random_state=42)
        self.verim_modeli.fit(X_scaled, y)
        joblib.dump(self.verim_modeli, 'verim_modeli.pkl')
        print("Verim modeli eğitildi ve kaydedildi.")
    def verim_tahmini(self, iklim: IklimVerisi, toprak: ToprakVerisi) -> float:
        """Yeni verilerle verim tahmini yapar"""
        if self.verim_modeli is None:
            raise Exception("Önce model eğitilmelidir!")
        # Özellikleri vektöre çevir
        ozellikler = np.array([[
            iklim.sicaklik, iklim.nem, iklim.gunUzunlugu, iklim.isikSiddeti,
            iklim.yagis, iklim.ruzgarHizi,
            toprak.pH, toprak.organikMadde, toprak.azot, toprak.fosfor, toprak.potasyum
        ]])
        ozellikler_scaled = self.scaler.transform(ozellikler)
        return self.verim_modeli.predict(ozellikler_scaled)[0]
    def kalite_modeli_egit(self, X, y):
        """X: iklim+toprak+bakım, y: uçucu yağ oranı (%)"""
        X_scaled = self.scaler.fit_transform(X)
        self.kalite_modeli = RandomForestRegressor(n_estimators=100, random_state=42)
        self.kalite_modeli.fit(X_scaled, y)
        joblib.dump(self.kalite_modeli, 'kalite_modeli.pkl')
        print("Kalite modeli eğitildi ve kaydedildi.")
    def kalite_tahmini(self, iklim: IklimVerisi, toprak: ToprakVerisi, bakim: Dict) -> float:
        """Bakım bilgileri (sulama sayısı, gübre miktarı vb.) ile kalite tahmini"""
        ozellikler = np.array([[
            iklim.sicaklik, iklim.nem, iklim.gunUzunlugu, iklim.isikSiddeti,
            iklim.yagis, iklim.ruzgarHizi,
            toprak.pH, toprak.organikMadde, toprak.azot, toprak.fosfor, toprak.potasyum,
            bakim.get("sulama_sayisi", 0), bakim.get("azot_gubre", 0), bakim.get("fosfor_gubre", 0)
        ]])
        ozellikler_scaled = self.scaler.transform(ozellikler)
        return self.kalite_modeli.predict(ozellikler_scaled)[0]
# ------------------------ 4. DERİN ÖĞRENME MODÜLÜ ------------------------
class DerinOgrenme:
    """
    Görüntü işleme ile bitki türü tanıma ve hastalık tespiti.
    """
    def __init__(self):
        self.bitki_tanima_modeli = None   # CNN
        self.hastalik_tanima_modeli = None
    def cnn_modeli_olustur(self, input_shape=(128, 128, 3), num_classes=10):
        """Basit bir CNN modeli tanımlar (transfer öğrenme de kullanılabilir)"""
        model = models.Sequential([
            layers.Conv2D(32, (3,3), activation='relu', input_shape=input_shape),
            layers.MaxPooling2D(2,2),
            layers.Conv2D(64, (3,3), activation='relu'),
            layers.MaxPooling2D(2,2),
            layers.Conv2D(128, (3,3), activation='relu'),
            layers.MaxPooling2D(2,2),
            layers.Flatten(),
            layers.Dense(512, activation='relu'),
            layers.Dense(num_classes, activation='softmax')
        ])
        model.compile(optimizer='adam', loss='categorical_crossentropy', metrics=['accuracy'])
        return model
    def bitki_tanima_modeli_egit(self, egitim_verisi, etiketler):
        """egitim_verisi: numpy array (resimler), etiketler: one-hot encoded"""
        self.bitki_tanima_modeli = self.cnn_modeli_olustur(num_classes=etiketler.shape[1])
        self.bitki_tanima_modeli.fit(egitim_verisi, etiketler, epochs=10, validation_split=0.2)
        self.bitki_tanima_modeli.save('bitki_tanima_modeli.h5')
        print("Bitki tanıma modeli eğitildi.")
    def bitki_tani(self, resim_yolu):
        """Resim dosyasından bitki türünü tahmin eder"""
        # Gerçek uygulamada resim yüklenir, ön işlenir ve model.predict() yapılır
        # Burada simülasyon
        tahmin = "kekik"  # örnek
        return tahmin
    def hastalik_tani(self, resim_yolu):
        """Yaprak resminden hastalık tespiti"""
        # Simülasyon
        hastalik = "külleme"  # örnek
        return hastalik
