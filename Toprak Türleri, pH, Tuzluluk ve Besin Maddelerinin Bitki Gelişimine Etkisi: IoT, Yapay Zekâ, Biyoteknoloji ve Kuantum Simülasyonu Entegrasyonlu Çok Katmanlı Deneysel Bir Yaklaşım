                     ",\"ec\":" + String(ec) + "}";
    int httpCode = http.POST(payload);
    Serial.println("HTTP Yanıt Kodu: " + String(httpCode));
    http.end();
  }
}
void loop() {
  float moisture = readMoisture();
  float ph = readPH();
  float ec = readEC();
