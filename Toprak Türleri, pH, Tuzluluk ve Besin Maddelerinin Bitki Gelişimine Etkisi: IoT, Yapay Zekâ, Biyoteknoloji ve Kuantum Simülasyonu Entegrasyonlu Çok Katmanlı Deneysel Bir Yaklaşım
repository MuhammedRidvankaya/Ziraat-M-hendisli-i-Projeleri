// Analog pin tanımları
const int moisturePin = 34;
const int phPin = 35;
const int ecPin = 32;
const int tempPin = 33;
void setup() {
  Serial.begin(115200);
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(1000);
    Serial.println("WiFi'ye bağlanıyor...");
  }
